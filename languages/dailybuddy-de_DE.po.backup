msgstr "Admin-Login-Link unten rechts anzeigen"

msgid "Admin Bar Notice"
msgstr "Hinweis in der Admin-Leiste"

msgid "Show warning in WordPress admin bar when mode is active"
msgstr "Warnhinweis in der WordPress-Admin-Leiste anzeigen, wenn der Modus aktiv ist"

msgid "Auto-End Mode"
msgstr "Automatisches Beenden"

msgid "Automatically disable maintenance mode at specific date/time"
msgstr "Wartungsmodus automatisch zu einem bestimmten Datum/Uhrzeit deaktivieren"


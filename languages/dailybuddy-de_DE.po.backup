# Plugin Description
msgid "A modular collection of essential WordPress features that can be individually enabled or disabled. Includes tools for duplicating posts, maintenance mode, media organization, custom widgets, and Elementor extensions - all in one place."
msgstr "Eine modulare Sammlung wichtiger WordPress-Funktionen, die einzeln aktiviert oder deaktiviert werden können. Enthält Tools zum Duplizieren von Beiträgen, Wartungsmodus, Medienorganisation, benutzerdefinierte Widgets und Elementor-Erweiterungen - alles an einem Ort."

# Main Menu
msgid "dailybuddy"
msgstr "dailybuddy"

# General
msgid "Settings"
msgstr "Einstellungen"

msgid "General Settings"
msgstr "Allgemeine Einstellungen"

msgid "Back to Modules"
msgstr "Zurück zu den Modulen"

msgid "Settings saved!"
msgstr "Einstellungen gespeichert!"

msgid "No permission"
msgstr "Keine Berechtigung"

msgid "Invalid module ID"
msgstr "Ungültige Modul-ID"

msgid "Module activated!"
msgstr "Modul aktiviert!"

msgid "Module deactivated"
msgstr "Modul deaktiviert"

msgid "Failed to save settings"
msgstr "Fehler beim Speichern der Einstellungen"

msgid "No modules available yet. Create your first module in the modules/ directory!"
msgstr "Noch keine Module vorhanden. Erstelle dein erstes Modul im modules/ Verzeichnis!"

msgid "Requires:"
msgstr "Benötigt:"

msgid "Module not found"
msgstr "Modul nicht gefunden"

msgid "This module has no settings"
msgstr "Dieses Modul hat keine Einstellungen"

# Categories
msgid "Essential WordPress utilities and tools"
msgstr "Wichtige WordPress-Werkzeuge und Tools"

msgid "Custom dashboard widgets and displays"
msgstr "Benutzerdefinierte Dashboard-Widgets und Anzeigen"

msgid "Additional widgets and features for Elementor"
msgstr "Zusätzliche Widgets und Funktionen für Elementor"

# Module: Duplicate Posts
msgid "Duplicate Posts/Pages"
msgstr "Seiten/Beiträge duplizieren"

msgid "Adds a \"Duplicate\" link to posts and pages."
msgstr "Fügt einen \"Duplizieren\" Link zu Seiten und Beiträgen hinzu."

msgid "Duplicate"
msgstr "Duplizieren"

msgid "No post to duplicate specified."
msgstr "Kein Beitrag zum Duplizieren angegeben."

msgid "Post not found."
msgstr "Beitrag nicht gefunden."

msgid "Error duplicating post."
msgstr "Fehler beim Duplizieren des Beitrags."

# Module: Media Folders
msgid "Media Library Folders"
msgstr "Mediathek Ordner"

msgid "Organize media library with folders (requires additional implementation)."
msgstr "Organisiert die Mediathek mit Ordnern (benötigt zusätzliche Implementierung)."

msgid "Media Folders module is active - Add your implementation here!"
msgstr "Media Folders Modul ist aktiviert - Füge hier deine Implementierung hinzu!"

# Module: Dashboard Widget
msgid "Custom Dashboard Widget"
msgstr "Benutzerdefiniertes Dashboard Widget"

msgid "Example dashboard widget - create your own widgets here."
msgstr "Beispiel für ein Dashboard Widget - hier kannst du deine eigenen Widgets erstellen."

# Module: Elementor Widgets
msgid "Elementor Widgets"
msgstr "Elementor Widgets"

msgid "Adds custom widgets to Elementor (requires Elementor plugin)."
msgstr "Fügt benutzerdefinierte Widgets zu Elementor hinzu (benötigt Elementor Plugin)."

msgid "Elementor Widgets module requires Elementor! Please install Elementor."
msgstr "Elementor Widgets Modul benötigt Elementor! Bitte installiere Elementor."

# Module: Under Construction
msgid "Under Construction Mode"
msgstr "Wartungsmodus"

msgid "Shows an \"Under Construction\" page for non-logged-in users."
msgstr "Zeigt eine \"Under Construction\" Seite für nicht angemeldete Benutzer."

msgid "Maintenance Mode"
msgstr "Wartungsmodus"

msgid "Website Under Construction"
msgstr "Website wird gerade überarbeitet"

msgid "We are currently working on improvements. Please check back soon!"
msgstr "Wir arbeiten derzeit an Verbesserungen. Bitte schauen Sie bald wieder vorbei!"

msgid "Page Title"
msgstr "Seitentitel"

msgid "The main heading shown on the maintenance page"
msgstr "Die Hauptüberschrift auf der Wartungsseite"

msgid "Message"
msgstr "Nachricht"

msgid "The message displayed below the title"
msgstr "Die Nachricht unter dem Titel"

msgid "Background Color"
msgstr "Hintergrundfarbe"

msgid "Choose a background color for the maintenance page"
msgstr "Wähle eine Hintergrundfarbe für die Wartungsseite"

msgid "Use Gradient"
msgstr "Farbverlauf verwenden"

msgid "Apply gradient effect to background"
msgstr "Farbverlauf auf Hintergrund anwenden"

msgid "Save Settings"
msgstr "Einstellungen speichern"

# General Settings Page
msgid "Plugin Settings"
msgstr "Plugin-Einstellungen"

msgid "Feedback System"
msgstr "Feedback-System"

msgid "Enable feedback system for module improvements"
msgstr "Feedback-System für Modul-Verbesserungen aktivieren"

msgid "Help us improve dailybuddy by sending anonymous usage data."
msgstr "Hilf uns dailybuddy zu verbessern, indem du anonyme Nutzungsdaten sendest."

msgid "Usage Analytics"
msgstr "Nutzungsanalyse"

msgid "Enable anonymous usage analytics"
msgstr "Anonyme Nutzungsanalyse aktivieren"

msgid "Track which modules are most used to prioritize future development."
msgstr "Verfolge welche Module am häufigsten genutzt werden, um die zukünftige Entwicklung zu priorisieren."

msgid "License"
msgstr "Lizenz"

msgid "License Key"
msgstr "Lizenzschlüssel"

msgid "Enter your license key to unlock premium features."
msgstr "Gib deinen Lizenzschlüssel ein, um Premium-Funktionen freizuschalten."

msgid "License Active"
msgstr "Lizenz aktiv"

msgid "No License Key"
msgstr "Kein Lizenzschlüssel"

msgid "Plugin Information"
msgstr "Plugin-Informationen"

msgid "Version"
msgstr "Version"

msgid "Author"
msgstr "Autor"

msgid "Documentation"
msgstr "Dokumentation"

msgid "View Documentation"
msgstr "Dokumentation ansehen"

